model Reviews {
    id String  @id @default(uuid())
    rating Int
    comment String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    userId String
    user User @relation(fields: [userId], references: [id])

    percelId String
    percel Percel @relation(fields: [percelId], references: [id])

    @@map("reviews")
}